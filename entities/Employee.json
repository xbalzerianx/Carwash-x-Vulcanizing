{
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string"
    },
    "contact_number": {
      "type": "string"
    },
    "commission_percentage": {
      "type": "number"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "avatar_color": {
      "type": "string"
    },
    "avatar_url": {
      "type": "string",
      "description": "Public URL of employee profile photo (Supabase Storage)"
    },
    "business_type": {
      "type": "string",
      "enum": [
        "carwash",
        "vulcanizing",
        "kgemployees"
      ],
      "default": "carwash",
      "description": "Which business unit this employee belongs to"
    },
    "monthly_rate": {
      "type": "number",
      "default": 0,
      "description": "Monthly salary (for monthly employees)"
    },
    "salary_type": {
      "type": "string",
      "enum": [
        "commission",
        "monthly"
      ],
      "default": "commission",
      "description": "commission = per work order, monthly = fixed monthly salary"
    },
    "employment_start_date": {
      "type": "string",
      "description": "Date salary cycle started (YYYY-MM-DD)"
    }
  },
  "required": [],
  "name": "Employee"
}